# PostgreSQL
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_CLIENT_ID=your-auth0-client-id

# CORS — comma-separated list of allowed frontend origins
# Local dev:   http://localhost:5173
# Production:  https://markriggs-dev.github.io,https://yourdomain.duckdns.org
CORS_ALLOWED_ORIGINS=http://localhost:5173

# React frontend (only needed when building the web-react container locally)
VITE_GATEWAY_URL=http://localhost:5000

# Email (for notification service — leave blank to disable)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
EMAIL_FROM=noreply@yourdomain.com

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# DuckDNS (NAS deployment only — leave blank for local dev)
DUCKDNS_SUBDOMAINS=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token
